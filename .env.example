# Optional public frontend config for web build
EXPO_PUBLIC_GOOGLE_MAPS_KEY=

# Cloud database connection
SUPABASE_DB_URL=jdbc:postgresql://aws-1-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require
SUPABASE_DB_USERNAME=postgres.tflsjdlyjnbgxeldaksl
SUPABASE_DB_PASSWORD=replace_with_actual_supabase_password

# If your password contains `$`, escape each one as `$$` in this root `.env`
# because Docker Compose treats `$...` as variable expansion.

# Optional cloud integrations
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@campuskonnect.local

# Demo secret override
JWT_SECRET=campuskonnect-demo-jwt-secret-key-change-me-2026
